#include "mcc_generated_files/system/system.h"

//LED-Port und Bitmasken
#define LEDS              PORTD.OUT
#define LED_MASK_ROT      0x10
#define LED_MASK_GELB1    0x20
#define LED_MASK_GELB2    0x40
#define LED_MASK_GRUEN    0x80

//Akku- und ADC-Parameter
#define VBAT_MAX_MV       4100U     // maximale Akkuspannung in mV
#define ADC_FULL_SCALE    4095U     // 12-Bit ADC, max. Zählwert

// Schwellenwerte für Ladezustände in mV
#define VBAT_THRESH_SOC0   3300U    // unterhalb: Akku leer (0 %)
#define VBAT_THRESH_SOC30  3700U    // ab 3.3 V bis unter 3.7 V -> ca. 30 %
#define VBAT_THRESH_SOC60  4000U    // ab 3.7 V bis unter 4.0 V -> ca. 60 %

// Ladezustände in Prozent
#define SOC_0_PERCENT     0U        // 0%
#define SOC_30_PERCENT    30U       // 30%
#define SOC_60_PERCENT    60U       // 60%
#define SOC_90_PERCENT    90U       // 90%

// letzter ADC-Rohwert (0..4095) der Akkumessung
static uint16_t adc_raw  = 0;

// berechnete Akkuspannung in Millivolt aus adc_raw
static uint16_t vbat_mV  = 0;

// Ladezustand des Akkus in Prozentstufen (0, 30, 60, 90)
static uint8_t  soc_pct  = 0;

// Misst die Akkuspannung am Kanal AIN29 und berechnet den Ladezustand.
static void BatteryMeasure(void)
{
    // Einzelmessung am Spannungsteiler des Akkus
    adc_raw = ADC0_ChannelSelectAndConvert(ADC0_CHANNEL_AIN29);

    // Umrechnung ADC-Wert -> Akkuspannung in mV bei VBAT_MAX_MV
    vbat_mV = (uint16_t)((adc_raw * VBAT_MAX_MV) / ADC_FULL_SCALE);

    /* Einteilung der gemessenen Akkuspannung in vier Bereiche:
    *  unter VBAT_THRESH_SOC0  -> Akku gilt als leer (0 %)
    *  zwischen VBAT_THRESH_SOC0 und VBAT_THRESH_SOC30  -> ca. 30 %
    *  zwischen VBAT_THRESH_SOC30 und VBAT_THRESH_SOC60 -> ca. 60 %
    *  ab VBAT_THRESH_SOC60   -> ca. 90 %
    */
    if (vbat_mV < VBAT_THRESH_SOC0)
    {
        // Akkuspannung kleiner als ca. 3.3 V -> Akku leer
        soc_pct = SOC_0_PERCENT;
    }
    else if (vbat_mV < VBAT_THRESH_SOC30)
    {
        // Akkuspannung zwischen ca. 3.3 V und 3.7 V -> etwa 30 %
        soc_pct = SOC_30_PERCENT;
    }
    else if (vbat_mV < VBAT_THRESH_SOC60)
    {
        // Akkuspannung zwischen ca. 3.7 V und 4.0 V -> etwa 60 %
        soc_pct = SOC_60_PERCENT;
    }
    else
    {
        // Akkuspannung ab ca. 4.0 V (bis ca. 4.1 V) -> etwa 90 %
        soc_pct = SOC_90_PERCENT;
    }
}

// Aktualisiert die vier Status-LEDs entsprechend dem Ladezustand.
static void BatteryLedsUpdate(void)
{
    /* Rote LED ist bereits gesetzt.
    * Je höher der Ladezustand, desto mehr LEDs werden zusätzlich eingeschaltet:
    * ab 30 %: erste gelbe LED
    * ab 60 %: zweite gelbe LED
    * ab 90 %: grüne LED
    */
   if (soc_pct >= SOC_30_PERCENT)
   {
       // Akku mindestens zu 30 % -> erste gelbe LED dazu
       LEDS |= LED_MASK_GELB1;
   }
   if (soc_pct >= SOC_60_PERCENT)
   {
       // Akku mindestens zu 60 % -> zweite gelbe LED dazu
       LEDS |= LED_MASK_GELB2;
   }
   if (soc_pct >= SOC_90_PERCENT)
   {
       // Akku mindestens zu 90 % -> grüne LED dazu
       LEDS |= LED_MASK_GRUEN;
   }
}

int main(void)
{
    SYSTEM_Initialize();

    while (1)
    {
        // Akkuspannung messen und Ladezustand soc_pct berechnen
        BatteryMeasure();

        // LEDs entsprechend dem berechneten Ladezustand aktualisieren
        BatteryLedsUpdate();
    }
}
