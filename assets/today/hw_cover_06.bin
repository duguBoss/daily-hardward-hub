// ======================== HELPER ========================
void formatCurrentDateTime(char* buf, size_t len) {
  if (timeStatus() == timeNotSet) {
    strlcpy(buf, "Ora non sincronizzata", len);
    return;
  }
  snprintf(buf, len, "%02d/%02d/%04d %02d:%02d:%02d",
           day(), month(), year(), hour(), minute(), second());
}

String jsonEscape(const char* s) {
  String out;
  while (*s) {
    char c = *s++;
    switch (c) {
      case '\"': out += F("\\\""); break;
      case '\\': out += F("\\\\"); break;
      case '\b': out += F("\\b"); break;
      case '\f': out += F("\\f"); break;
      case '\n': out += F("\\n"); break;
      case '\r': out += F("\\r"); break;
      case '\t': out += F("\\t"); break;
      default:
        if ((uint8_t)c < 0x20) out += ' ';
        else out += c;
        break;
    }
  }
  return out;
}

const char* windDirToText(int deg) {
  static const char* dirs[] = {
    "N", "NNE", "NE", "ENE",
    "E", "ESE", "SE", "SSE",
    "S", "SSW", "SW", "WSW",
    "W", "WNW", "NW", "NNW"
  };
  int idx = (int)roundf(deg / 22.5f) % 16;
  return dirs[idx];
}

void startTransmissionFlash() {
  isFlashing = true;
  flashStartTime = millis();
}

String getResetReasonString() {
  esp_reset_reason_t reason = esp_reset_reason();

  switch (reason) {
    case ESP_RST_UNKNOWN: return "Unknown";
    case ESP_RST_POWERON: return "Power on reset";
    case ESP_RST_EXT: return "External reset";
    case ESP_RST_SW: return "Software reset";
    case ESP_RST_PANIC: return "Exception/Panic";
    case ESP_RST_INT_WDT: return "Interrupt watchdog";
    case ESP_RST_TASK_WDT: return "Task watchdog";
    case ESP_RST_WDT: return "Other watchdog";
    case ESP_RST_DEEPSLEEP: return "Deep sleep wake";
    case ESP_RST_BROWNOUT: return "Brownout";
    case ESP_RST_SDIO: return "SDIO reset";
    default: return "Unmapped reset reason";
  }
}

void checkAppWatchdog() {
  if (millis() - appWatchdogLastKick > APP_WDT_TIMEOUT) {
    wdtRestartTriggered = true;
  }
}

void saveResetEvent() {
  File f = LittleFS.open("/reset_log.txt", "a");
  if (!f) return;
  char ts[24];
  formatCurrentDateTime(ts, sizeof(ts));
  f.print(ts);
  f.print(F(" - "));
  f.print(getResetReasonString());
  f.print('\n');
  f.close();
}

void logError(const String& message) {
  char ts[24];
  if (timeStatus() == timeNotSet) strlcpy(ts, "Offline", sizeof(ts));
  else formatCurrentDateTime(ts, sizeof(ts));

  File f = LittleFS.open("/error_log.txt", "a");
  if (f) {
    f.print(ts);
    f.print(F(" - "));
    f.print(message);
    f.print('\n');
    f.close();
  }
}

void urlEncode(const char* src, char* dst, size_t dstSize) {
  static const char hex[] = "0123456789ABCDEF";
  size_t j = 0;
  for (size_t i = 0; src[i] != '\0' && j + 1 < dstSize; i++) {
    uint8_t c = (uint8_t)src[i];
    bool safe = (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '-' || c == '_' || c == '.' || c == '~';
    if (safe) {
      dst[j++] = (char)c;
    } else {
      if (j + 3 >= dstSize) break;
      dst[j++] = '%';
      dst[j++] = hex[(c >> 4) & 0x0F];
      dst[j++] = hex[c & 0x0F];
    }
  }
  dst[j] = '\0';
}

void smartDelay(unsigned long duration) {
  unsigned long start = millis();
  while (millis() - start < duration) {
    getRain();
    httpServer.handleClient();
    ElegantOTA.loop();
    appWatchdogLastKick = millis();
    delay(1);
  }
}

void drainClient(WiFiClient& client) {
  unsigned long start = millis();
  while (millis() - start < 1500UL) {
    while (client.available()) {
      client.read();
      start = millis();
    }
    if (!client.connected()) break;
    delay(2);
  }
}

bool checkInternet() {
  WiFiClient c1;
  if (c1.connect(IPAddress(1, 1, 1, 1), 80)) {
    c1.stop();
    return true;
  }
  WiFiClient c2;
  if (c2.connect(IPAddress(8, 8, 8, 8), 53)) {
    c2.stop();
    return true;
  }
  return false;
}

// ======================== TCP HELPERS ========================
bool safeConnect(WiFiClient& client, const char* host, uint16_t port) {
  unsigned long start = millis();
  while (!client.connect(host, port)) {
    if (millis() - start > TCP_CONNECT_WAIT) return false;
    appWatchdogLastKick = millis();
    delay(20);
  }
  return true;
}

bool safeWaitResponse(WiFiClient& client) {
  unsigned long start = millis();
  while (!client.available()) {
    if (millis() - start > TCP_RESPONSE_WAIT) return false;
    appWatchdogLastKick = millis();
    delay(10);
  }
  return true;
}

int readHttpStatus(WiFiClient& client, unsigned long timeout_ms = TCP_RESPONSE_WAIT) {
  unsigned long start = millis();
  char statusLine[64] = { 0 };
  size_t idx = 0;

  while (millis() - start < timeout_ms) {
    while (client.available()) {
      char c = client.read();
      if (c == '\r') continue;
      if (c == '\n') {
        statusLine[idx] = '\0';
        char* fs = strchr(statusLine, ' ');
        if (!fs) return -1;
        return atoi(fs + 1);
      }
      if (idx + 1 < sizeof(statusLine)) statusLine[idx++] = c;
    }
    appWatchdogLastKick = millis();
    delay(5);
  }
  return -1;
}

// ======================== ISR ========================
volatile unsigned long last_micros_rot = 0;

void IRAM_ATTR isr_rotation() {
  unsigned long m = micros();
  if (m - last_micros_rot > WIND_DEBOUNCE_US) {
    Rotations++;
    last_micros_rot = m;
  }
}

void IRAM_ATTR isr_rg() {
  if ((millis() - contactTime) > 150) {
    rainTips1h++;
    rainTips24h++;
    rainDataToSave = true;
    contactTime = millis();
  }
}

// ======================== BATTERIA ========================
void readBatteryVoltage() {
  int raw = analogRead(batteryPin);
  const float ADC_MAX = 4095.0f;
  const float ADC_REF = 3.3f;

  float v = ((float)raw / ADC_MAX) * ADC_REF * BATTERY_DIVIDER_FACTOR;

  battBuffer[battIndex] = v;
  battIndex++;
  if (battIndex >= BATT_SAMPLES) {
    battIndex = 0;
    battBufferFull = true;
  }

  int n = battBufferFull ? BATT_SAMPLES : battIndex;
  float sum = 0.0f;
  for (int i = 0; i < n; i++) sum += battBuffer[i];
  batteryVoltage = (n > 0) ? (sum / n) : v;
}

// ======================== DIREZIONE ========================
float readWindDirection() {
  uint16_t samples[8];
  uint32_t sum = 0;

  for (int i = 0; i < 8; i++) {
    samples[i] = analogRead(WindDirPin);
  }

  uint16_t minv = samples[0];
  uint16_t maxv = samples[0];

  for (int i = 0; i < 8; i++) {
    if (samples[i] < minv) minv = samples[i];
    if (samples[i] > maxv) maxv = samples[i];
    sum += samples[i];
  }

  // Media robusta: scarta il valore minimo e massimo
  float adc_val = (sum - minv - maxv) / 6.0f;

  float dir = (adc_val / 4095.0f) * 360.0f;

  while (dir >= 360.0f) dir -= 360.0f;
  while (dir < 0.0f) dir += 360.0f;

  const float alpha = 0.2f;
  float delta = dir - dir_filtered;
  if (delta > 180.0f) delta -= 360.0f;
  if (delta < -180.0f) delta += 360.0f;

  dir_filtered += alpha * delta;
  if (dir_filtered < 0.0f) dir_filtered += 360.0f;
  if (dir_filtered >= 360.0f) dir_filtered -= 360.0f;

  return dir_filtered;
}

// ======================== PROCESSO VENTO con finestra scorrevole 10min e direzione raffica ========================

// NUOVA FUNZIONE HELPER: Rimuove in sicurezza il campione più vecchio aggiornando tutti i totali
void wmo_pop_oldest() {
  if (wmoCount == 0) return;

  WindSample& old = wmoBuffer[wmoHead];

  // Sottrai dai totali in modo sicuro
  wmo_sum_speed -= old.speed;
  wmo_sum_sin -= old.dir_sin;
  wmo_sum_cos -= old.dir_cos;

  // Se stiamo per cancellare il campione che deteneva il picco della raffica, ricalcoliamolo
  if (old.gust3 >= wmo_max_gust3 - 1e-6f) {
    float mx = 0.0f;
    float dir_at_mx = 0.0f;
    for (int i = 1; i < wmoCount; ++i) {
      int idx = (wmoHead + i) % WMO_MAX_SAMPLES;
      if (wmoBuffer[idx].gust3 > mx) {
        mx = wmoBuffer[idx].gust3;
        dir_at_mx = wmoBuffer[idx].dir_deg;
      }
    }
    wmo_max_gust3 = mx;
    wmo_dir_at_max_gust = dir_at_mx;
  }

  // Sposta la testa ed elimina effettivamente il campione
  wmoHead = (wmoHead + 1) % WMO_MAX_SAMPLES;
  wmoCount--;
}

void wmo_prune_old(uint32_t now_sec) {
  // Rimuove i campioni più vecchi di WMO_WINDOW_SEC usando la funzione sicura
  while (wmoCount > 0) {
    if ((int32_t)(now_sec - wmoBuffer[wmoHead].ts) <= WMO_WINDOW_SEC) break;
    wmo_pop_oldest();
  }
}

void wmo_push_sample(uint32_t ts_sec, float speed_raw, float dir_deg) {
  /*
  // calcola gust3 (media degli ultimi 3 speed_raw)
  last3_speed[last3_idx] = speed_raw;
  last3_idx = (last3_idx + 1) % 3;
  if (last3_count < 3) last3_count++;
  float sum3 = 0.0f;
  for (int i = 0; i < last3_count; ++i) sum3 += last3_speed[i];
  float gust3 = (last3_count > 0) ? (sum3 / last3_count) : speed_raw;
*/
  // Con campionamento a 3000ms, speed_raw È la raffica WMO ufficiale a 3 secondi!
  float gust3 = speed_raw;

  // FIX FONDAMENTALE: Se il buffer è già pieno, estrai il più vecchio PRIMA di sovrascriverlo!
  if (wmoCount >= WMO_MAX_SAMPLES) {
    wmo_pop_oldest();
  }

  // prepara sample
  WindSample s;
  s.ts = ts_sec;
  s.speed = speed_raw;
  s.dir_deg = dir_deg;
  float rad = dir_deg * DEG_TO_RAD;
  s.dir_sin = sinf(rad) * speed_raw;
  s.dir_cos = cosf(rad) * speed_raw;
  s.gust3 = gust3;

  // append in buffer (tail index) in sicurezza
  int tail = (wmoHead + wmoCount) % WMO_MAX_SAMPLES;
  wmoBuffer[tail] = s;
  wmoCount++;

  // aggiorna somme e max
  wmo_sum_speed += s.speed;
  wmo_sum_sin += s.dir_sin;
  wmo_sum_cos += s.dir_cos;

  if (s.gust3 > wmo_max_gust3) {
    wmo_max_gust3 = s.gust3;
    wmo_dir_at_max_gust = s.dir_deg;
  }
}

void processWindData() {
  uint32_t now = millis();

  if (now - last_dir_sample >= DIR_SAMPLE_INTERVAL) {
    last_dir_sample = now;
    float dir = readWindDirection();
    last_dir_measurement = dir;
    dir_sin_bucket += sinf(dir * DEG_TO_RAD);
    dir_cos_bucket += cosf(dir * DEG_TO_RAD);
    dir_bucket_samples++;
  }

  if (now - last_speed_sample >= WIND_SAMPLE_INTERVAL) {
    uint32_t dt = now - last_speed_sample;
    if (dt == 0) dt = WIND_SAMPLE_INTERVAL;
    last_speed_sample = now;

    noInterrupts();
    uint32_t rot = Rotations;
    Rotations = 0;
    interrupts();

    float speed_raw = ((float)rot / (dt / 1000.0f)) * WIND_FACTOR_MPH;

    // =========================================================
    // VALIDAZIONE ANOMALIE IMPULSIVE COMBINATE VENTO + PIOGGIA
    // Interviene solo su eventi estremi e simultanei.
    // =========================================================
    static uint32_t last_validated_rainTips1h = 0;
    static uint32_t last_validated_rainTips24h = 0;
    static float last_validated_speed_raw = 0.0f;

    uint32_t rain1h_now, rain24h_now;
    noInterrupts();
    rain1h_now = rainTips1h;
    rain24h_now = rainTips24h;
    interrupts();

    uint32_t rain_delta_1h =
      (rain1h_now >= last_validated_rainTips1h) ? (rain1h_now - last_validated_rainTips1h) : rain1h_now;

    uint32_t rain_delta_24h =
      (rain24h_now >= last_validated_rainTips24h) ? (rain24h_now - last_validated_rainTips24h) : rain24h_now;

    uint32_t rain_delta = (rain_delta_24h > rain_delta_1h) ? rain_delta_24h : rain_delta_1h;

    float raw_before_anomaly_checks = speed_raw;
    float wind_jump = raw_before_anomaly_checks - last_validated_speed_raw;

    bool absurdRainSolo = (rain_delta >= ANOMALY_RAIN_TIPS_SOLO);
    bool absurdWindNow =
      (raw_before_anomaly_checks >= ANOMALY_WIND_ABS_MPH) && (wind_jump >= ANOMALY_WIND_JUMP_MPH);

    bool combinedImpulseAnomaly =
      (rain_delta >= ANOMALY_RAIN_TIPS_COMBINED) && absurdWindNow;

    if (absurdRainSolo || combinedImpulseAnomaly) {
      noInterrupts();
      rainTips1h = last_validated_rainTips1h;
      rainTips24h = last_validated_rainTips24h;
      interrupts();

      speed_raw = last_valid_speed;
      anomalyEvents++;

      char msg[180];
      snprintf(msg, sizeof(msg),
               "ANOMALIA IMPULSIVA scartata: rainTips+%lu windRaw=%.1f mph jump=%.1f mph",
               (unsigned long)rain_delta,
               raw_before_anomaly_checks,
               wind_jump);
      logError(msg);
    }

    // Limite assoluto finale coerente con il massimo fisico accettato
    if (speed_raw > 106.0f) {
      speed_raw = last_valid_speed;
    }

    last_validated_rainTips1h = rainTips1h;
    last_validated_rainTips24h = rainTips24h;
    last_validated_speed_raw = speed_raw;

    last_valid_speed = speed_raw;

    float alpha;
    if (speed_raw < 1.0f) alpha = 0.15f;
    else if (speed_raw < 5.0f) alpha = 0.25f;
    else alpha = 0.4f;

    windSpeed_ema = alpha * speed_raw + (1.0f - alpha) * windSpeed_ema;
    windSpeed = windSpeed_ema;

    uint32_t now_sec = millis() / 1000UL;
    wmo_push_sample(now_sec, speed_raw, last_dir_measurement);
    wmo_prune_old(now_sec);

    if (wmoCount > 0) {
      wind_speed_avg = wmo_sum_speed / (float)wmoCount;

      float meanRad = atan2f(wmo_sum_sin, wmo_sum_cos);
      float meanDeg = meanRad * RAD_TO_DEG;
      if (meanDeg < 0.0f) meanDeg += 360.0f;
      windDirWMO = (int)lroundf(meanDeg) % 360;
    } else {
      wind_speed_avg = 0.0f;
      windDirWMO = (int)roundf(last_dir_measurement) % 360;
    }

    int tail = (wmoHead + wmoCount - 1 + WMO_MAX_SAMPLES) % WMO_MAX_SAMPLES;
    if (wmoCount > 0) windgustmph = wmoBuffer[tail].gust3;
    else windgustmph = windSpeed_ema;

    windgust_peak_mph = wmo_max_gust3;
  }
}

// ======================== EEPROM / PIOGGIA ========================
void saveRainData() {
  uint32_t t1, t24;
  noInterrupts();
  t1 = rainTips1h;
  t24 = rainTips24h;
  interrupts();

  EEPROM.put(0, t1);
  EEPROM.put(sizeof(uint32_t), t24);
  EEPROM.put(sizeof(uint32_t) * 2, (byte)day());
  EEPROM.commit();
}

void loadRainData() {
  uint32_t t1 = 0, t24 = 0;
  byte savedDay = 0;

  EEPROM.get(0, t1);
  EEPROM.get(sizeof(uint32_t), t24);
  EEPROM.get(sizeof(uint32_t) * 2, savedDay);

  noInterrupts();
  if (timeStatus() == timeNotSet) {
    rainTips1h = t1;
    rainTips24h = t24;
  } else {
    if (savedDay != (byte)day()) {
      rainTips1h = 0;
      rainTips24h = 0;
    } else {
      rainTips1h = t1;
      rainTips24h = t24;
    }
  }
  interrupts();

  if (timeStatus() != timeNotSet && savedDay != (byte)day()) saveRainData();
}

// ======================== NTP ========================
time_t getNtpTimeDynamic() {
  while (Udp.parsePacket() > 0) {}

  IPAddress ntpIP;
  // Prova con Google, se fallisce prova con l'Istituto Italiano, se fallisce usa il Pool Europeo
  if (!WiFi.hostByName("time.google.com", ntpIP)) {
    if (!WiFi.hostByName("ntp1.inrim.it", ntpIP)) {
      if (!WiFi.hostByName("europe.pool.ntp.org", ntpIP)) {
        return 0;
      }
    }
  }

  memset(packetBuffer, 0, NTP_PACKET_SIZE);
  packetBuffer[0] = 0b11100011;

  Udp.beginPacket(ntpIP, 123);
  Udp.write(packetBuffer, NTP_PACKET_SIZE);
  Udp.endPacket();

  uint32_t t0 = millis();
  while (millis() - t0 < 3000UL) {
    if (Udp.parsePacket() >= NTP_PACKET_SIZE) {
      Udp.read(packetBuffer, NTP_PACKET_SIZE);
      unsigned long s =
        ((unsigned long)packetBuffer[40] << 24) | ((unsigned long)packetBuffer[41] << 16) | ((unsigned long)packetBuffer[42] << 8) | ((unsigned long)packetBuffer[43]);

      // Calcola l'ora UTC esatta (meridiano di Greenwich)
      time_t utcTime = s - 2208988800UL;

      // Chiede alla libreria Timezone in quale regime ci troviamo in questo preciso istante
      TimeChangeRule* tcr;
      CE.toLocal(utcTime, &tcr);

      // tcr->offset restituisce 120 (legale) o 60 (solare). Lo dividiamo per 60 per ottenere le ore (1 o 2).
      timec = tcr->offset / 60;

      // Restituisce l'ora locale perfetta da impostare nel sistema
      return utcTime + (timec * SECS_PER_HOUR);
    }
    appWatchdogLastKick = millis();
    delay(1);
  }
  return 0;
}

// ======================== CALCOLI ========================
double dewPoint(double tC, double RH) {
  if (RH <= 0.0 || RH > 100.0 || isnan(tC) || isnan(RH)) return -999.0;
  const double a = 17.62, b = 243.12;
  double gamma = (a * tC) / (b + tC) + log(RH / 100.0);
  return (b * gamma) / (a - gamma);
}

void windchill() {
  float tf = (tempc * 9.0f) / 5.0f + 32.0f;
  if (tf < 50.0f && wind_speed_avg > 3.0f) {
    float cf = 35.74f + 0.6215f * tf - 35.75f * powf(wind_speed_avg, 0.16f) + 0.4275f * tf * powf(wind_speed_avg, 0.16f);
    chill_c = (cf - 32.0f) * 5.0f / 9.0f;
  } else {
    chill_c = tempc;
  }
}

void heatindex() {
  temp_f = (tempc * 9.0f) / 5.0f + 32.0f;
  if (isnan(temp_f) || isnan(humidity) || temp_f < 80.0f || humidity < 0.0f || humidity > 100.0f) {
    heat_c = tempc;
    return;
  }

  float hf = -42.379f + 2.04901523f * temp_f + 10.14333127f * humidity
             - 0.22475541f * temp_f * humidity - 0.00683783f * temp_f * temp_f
             - 0.05481717f * humidity * humidity
             + 0.00122874f * temp_f * temp_f * humidity
             + 0.00085282f * temp_f * humidity * humidity
             - 0.00000199f * temp_f * temp_f * humidity * humidity;

  if (humidity < 13.0f && temp_f >= 80.0f && temp_f <= 112.0f)
    hf -= ((13.0f - humidity) / 4.0f) * sqrtf((17.0f - fabsf(temp_f - 95.0f)) / 17.0f);
  else if (humidity > 85.0f && temp_f >= 80.0f && temp_f <= 87.0f)
    hf += ((humidity - 85.0f) / 10.0f) * ((87.0f - temp_f) / 5.0f);

  heat_c = (hf - 32.0f) * 5.0f / 9.0f;
}

void checkHumidityStability() {
  static unsigned long lastCheck = 0;
  static float lastHum = 0.0f;
  static int stableCnt = 0;

  if (millis() - lastCheck < 60000UL) return;
  lastCheck = millis();

  if (humidity > 99.0f && fabsf(humidity - lastHum) < 0.2f) stableCnt++;
  else stableCnt = 0;

  lastHum = humidity;

  if (stableCnt >= 30) {
    sht31.heater(true);
    delay(5000);
    sht31.heater(false);
    stableCnt = 0;
  }
}

float getSeaLevelPressure(float p, float tC, float alt, float hum) {
  if (isnan(p) || p < 500.0f) return p;
  if (isnan(tC)) tC = 15.0f;
  if (isnan(hum) || hum < 0.0f || hum > 100.0f) hum = 50.0f;

  float Ts = tC + 273.15f;
  float Es = 6.112f * expf((17.62f * tC) / (243.12f + tC));
  float e = (hum / 100.0f) * Es;
  float Tv = Ts / (1.0f - (e / p) * 0.378f);
  float Tmv = Tv + (0.0065f * alt / 2.0f);

  return p * expf(alt / (29.28f * Tmv));
}

// ======================== LETTURA SENSORI ========================
void read_data() {
  DS18B20.requestTemperatures();
  float rt = DS18B20.getTempCByIndex(0);
  float rh = sht31.readHumidity();

  bool tOk = (!isnan(rt) && rt >= -40.0f && rt <= 80.0f);
  bool hOk = (!isnan(rh) && rh >= 5.0f && rh <= 100.0f);

  if (tOk) {
    tempBuffer[thIndex] = rt;
    sensorFailCount_DS18B20 = 0;
  } else if (sensorFailCount_DS18B20 < 250) {
    sensorFailCount_DS18B20++;
  }

  if (hOk) {
    humBuffer[thIndex] = rh;
    sensorFailCount_SHT31 = 0;
  } else if (sensorFailCount_SHT31 < 250) {
    sensorFailCount_SHT31++;
  }

  thIndex++;
  if (thIndex >= TEMP_HUM_SAMPLES) {
    thIndex = 0;
    thBufferFull = true;
  }

  int n = thBufferFull ? TEMP_HUM_SAMPLES : thIndex;
  float sumT = 0.0f, sumH = 0.0f;
  for (int i = 0; i < n; i++) {
    sumT += tempBuffer[i];
    sumH += humBuffer[i];
  }

  tempc = (n > 0 && tOk) ? (sumT / n) : -999.0f;
  humidity = (n > 0 && hOk) ? (sumH / n) : 0.0f;

  if (tempc > -999.0f && tempc < tempc_min) tempc_min = tempc;

  float rp = bmp.readPressure() / 100.0f;
  float rt_bmp = bmp.readTemperature();

  if (!isnan(rp) && rp >= 700.0f && rp <= 1100.0f && rp != 0.0f) {
    sensorFailCount_BMP280 = 0;
  } else if (sensorFailCount_BMP280 < 250) {
    sensorFailCount_BMP280++;
  }

  float tForSlp = (tempc > -999.0f) ? tempc : ((!isnan(rt_bmp) && rt_bmp != 0.0f) ? rt_bmp : 15.0f);
  float hForSlp = (humidity >= 5.0f && humidity <= 100.0f) ? humidity : 50.0f;
  float calcP = getSeaLevelPressure(rp, tForSlp, altitudepws, hForSlp) + PRESSURE_OFFSET_HPA;

  static bool diagNotified = false;
  if (rp < 700.0f || rp > 1100.0f || isnan(rp) || rp == 0.0f) {
    if (!diagNotified) {
      sendTelegramMessage("ERRORE BME/BMP280");
      diagNotified = true;
    }
    baromhpa = last_baromhpa;
  } else {
    if (diagNotified) {
      sendTelegramMessage("BME/BMP280 ripristinato");
      diagNotified = false;
    }
    baromhpa = calcP;
    last_baromhpa = baromhpa;
  }

  pressurehPa = baromhpa;
  baromin = baromhpa / 33.86f;
  temp_f = (tempc > -999.0f) ? (tempc * 9.0f / 5.0f + 32.0f) : -999.0f;

  if (tempc > -999.0f && humidity >= 5.0f) {
    dewpt_c = (float)dewPoint((double)tempc, (double)humidity);
    dewpt_f = (dewpt_c > -999.0f) ? (dewpt_c * 9.0f / 5.0f + 32.0f) : -999.0f;
  } else {
    dewpt_c = -999.0f;
    dewpt_f = -999.0f;
  }

  windchill();
  heatindex();
}

// ======================== RECOVERY SENSORI ========================
void recoverSensorsIfNeeded() {
  if (millis() - lastSensorRecovery < SENSOR_RECOVERY_MS) return;
  lastSensorRecovery = millis();

  bool didSomething = false;

  if (sensorFailCount_DS18B20 >= 3) {
    DS18B20.begin();
    sensorFailCount_DS18B20 = 0;
    didSomething = true;
  }

  if (sensorFailCount_SHT31 >= 3) {
    sht31.begin(0x44);
    sensorFailCount_SHT31 = 0;
    didSomething = true;
  }

  if (sensorFailCount_BMP280 >= 3) {
    if (!bmp.begin(0x76)) bmp.begin(0x77);
    sensorFailCount_BMP280 = 0;
    didSomething = true;
  }

  if (didSomething) logError("Recovery sensori eseguito");
}

// ======================== PIOGGIA ========================
void getRain() {
  uint32_t local1h, local24h;
  noInterrupts();
  local1h = rainTips1h;
  local24h = rainTips24h;
  interrupts();

  rain_1h_mm = local1h * Bucket_Size_EU;
  rain_24h_mm = local24h * Bucket_Size_EU;

  static int lastMin = -1;
  if (timeStatus() != timeNotSet) {
    if (minute() != lastMin) {
      if (minute() == 0) {
        noInterrupts();
        rainTips1h = 0;
        interrupts();
        saveRainData();
      }
      lastMin = minute();
    }

    static int lastDay2 = -1;
    if (lastDay2 == -1) lastDay2 = day();
    if (day() != lastDay2 && hour() == 0 && minute() == 0) {
      noInterrupts();
      rainTips24h = 0;
      interrupts();
      saveRainData();
      lastDay2 = day();
    }
  }
}

// ======================== TELEGRAM ========================
void sendTelegramMessage(const char* text) {
  if (WiFi.status() != WL_CONNECTED) return;
  if (strcmp(BOT_TOKEN, "INSERISCI_IL_TUO_VERO_TOKEN_QUI") == 0) return;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  static char encoded[700];
  static char url[1024];

  urlEncode(text, encoded, sizeof(encoded));
  snprintf(url, sizeof(url),
           "https://api.telegram.org/bot%s/sendMessage?chat_id=%s&text=%s",
           BOT_TOKEN, CHAT_ID, encoded);

  if (http.begin(client, url)) {
    http.setTimeout(4000);
    http.GET();
    http.end();
  }
}

void sendTelegramMessage(const String& text) {
  sendTelegramMessage(text.c_str());
}

// Legge fino a maxLen caratteri dal client e restituisce come String
String readClientBody(Client& client, size_t maxLen = 2048, unsigned long timeoutMs = 2000) {
  String body = "";
  unsigned long start = millis();
  while (client.connected() && (millis() - start) < timeoutMs) {
    while (client.available()) {
      char c = client.read();
      body += c;
      if (body.length() >= (int)maxLen) return body;
    }
    delay(1);
  }
  // Se non connesso, prova a leggere eventuale rimanenza
  while (client.available()) {
    char c = client.read();
    body += c;
    if (body.length() >= (int)maxLen) break;
  }
  return body;
}

// ======================== HELPER INVIO DATI HTTP (PULITO) ========================
bool sendHttpRequest(WiFiClient& client, const char* host, const String& request) {
  if (client.connected()) client.stop();

  if (safeConnect(client, host, 80)) {
    client.print(request);

    if (safeWaitResponse(client)) {
      int code = readHttpStatus(client);

      // Leggiamo il body per svuotare il buffer, ma non lo salviamo più nella RAM!
      readClientBody(client, 4096, 2500);

      if (code == 200 || code == 204) {
        drainClient(client);
        client.stop();
        return true;
      }
    }
    client.stop();
  }
  return false;
}

// ======================== WUNDERGROUND ========================
void wunderground() {
  isTransmitting = true;
  bool wmoReady = (wmoCount >= 200);

  float ws_send = wmoReady ? wind_speed_avg : windSpeed_ema;
  float gust_send = wmoReady ? wmo_max_gust3 : windgustmph;
  if (gust_send < ws_send) gust_send = ws_send;

  int dir_send = wmoReady ? windDirWMO : (int)roundf(last_dir_measurement);
  float gust_dir_send = wmoReady ? wmo_dir_at_max_gust : last_dir_measurement;

  char buf[512];
  snprintf(buf, sizeof(buf),
           "%sID=%s&PASSWORD=%s&dateutc=now&winddir=%d&windspeedmph=%.1f&windgustmph=%.1f&windgustdir=%.0f"
           "&tempf=%.2f&dewptf=%.2f&humidity=%.2f&baromin=%.2f&rainin=%.3f&dailyrainin=%.3f"
           "&softwaretype=ESP32&action=updateraw&realtime=1&rtfreq=30",
           WEBPAGE, ID, PASSWORD, dir_send, ws_send, gust_send, gust_dir_send,
           temp_f, dewpt_f, humidity, baromin, rain_1h_mm / 25.4f, rain_24h_mm / 25.4f);

  String request = String(buf) + " HTTP/1.1\r\nHost: rtupdate.wunderground.com\r\nConnection: close\r\n\r\n";

  bool ok = false;
  for (int attempt = 1; attempt <= 3 && !ok; attempt++) {
    ok = sendHttpRequest(wuClient, server, request);
    if (ok) {
      startTransmissionFlash();
    } else if (attempt < 3) {
      smartDelay(2000UL * (1UL << (attempt - 1)));
    }
  }

  if (ok) consecutiveFailures = 0;
  else {
    consecutiveFailures++;
    if (consecutiveFailures > maxWuFails) maxWuFails = consecutiveFailures;
    logError("Fallimento WU");
  }

  isTransmitting = false;
}

// ======================== WEATHERCLOUD ========================
void weathercloud() {
  isTransmitting = true;

  bool wmoReady = (wmoCount >= 200);

  float ws_inst_send = windSpeed_ema;
  float ws_avg_send = wmoReady ? wind_speed_avg : windSpeed_ema;
  float gust_send = wmoReady ? wmo_max_gust3 : windgustmph;
  if (gust_send < ws_avg_send) gust_send = ws_avg_send;

  int dir_send = wmoReady ? windDirWMO : (int)roundf(last_dir_measurement);
  int dir_avg_send = dir_send;

  // Conversione mph -> m/s per Weathercloud
  float ws_inst_ms = ws_inst_send * 0.44704f;
  float ws_avg_ms  = ws_avg_send  * 0.44704f;
  float gust_ms    = gust_send    * 0.44704f;

  // Dew point gia' disponibile nel firmware
  float dew_send_c = dewpt_c;

  // Wind chill calcolato localmente in gradi C
  float chill_send_c = tempc;
  float ws_avg_kmh = ws_avg_send * 1.60934f;
  if (tempc <= 10.0f && ws_avg_kmh > 4.8f) {
    chill_send_c =
      13.12f + 0.6215f * tempc
      - 11.37f * powf(ws_avg_kmh, 0.16f)
      + 0.3965f * tempc * powf(ws_avg_kmh, 0.16f);
  }

  // Heat index calcolato localmente in gradi C
  float heat_send_c = tempc;
  if (tempc >= 27.0f && humidity >= 40.0f) {
    float tf = tempc * 9.0f / 5.0f + 32.0f;
    float hif =
      -42.379f
      + 2.04901523f * tf
      + 10.14333127f * humidity
      - 0.22475541f * tf * humidity
      - 0.00683783f * tf * tf
      - 0.05481717f * humidity * humidity
      + 0.00122874f * tf * tf * humidity
      + 0.00085282f * tf * humidity * humidity
      - 0.00000199f * tf * tf * humidity * humidity;
    heat_send_c = (hif - 32.0f) * 5.0f / 9.0f;
  }

  char buf[512];
  snprintf(buf, sizeof(buf),
           "/v01/set/wid/%s/key/%s"
           "/temp/%d"
           "/hum/%d"
           "/bar/%d"
           "/dew/%d"
           "/chill/%d"
           "/heat/%d"
           "/wdir/%d"
           "/wdiravg/%d"
           "/wspd/%d"
           "/wspdavg/%d"
           "/wspdhi/%d"
           "/rain/%d"
           "/rainrate/%d",
           ID2, Key2,
           (int)roundf(tempc * 10.0f),
           (int)roundf(humidity),
           (int)roundf(pressurehPa * 10.0f),
           (int)roundf(dew_send_c * 10.0f),
           (int)roundf(chill_send_c * 10.0f),
           (int)roundf(heat_send_c * 10.0f),
           dir_send,
           dir_avg_send,
           (int)roundf(ws_inst_ms * 10.0f),
           (int)roundf(ws_avg_ms * 10.0f),
           (int)roundf(gust_ms * 10.0f),
           (int)roundf(rain_24h_mm * 10.0f),
           (int)roundf(rain_1h_mm * 10.0f));

  String request = "GET " + String(buf) + " HTTP/1.1\r\nHost: api.weathercloud.net\r\nConnection: close\r\n\r\n";

  bool ok = false;
  for (int attempt = 1; attempt <= 3 && !ok; attempt++) {
    ok = sendHttpRequest(wcClient, server2, request);
    if (ok) {
      startTransmissionFlash();
    } else if (attempt < 3) {
      smartDelay(2000UL * (1UL << (attempt - 1)));
    }
  }

  if (ok) wcFailures = 0;
  else wcFailures++;

  isTransmitting = false;
}



// ======================== THINGSPEAK ========================
void thingspeak() {
  isTransmitting = true;
  bool wmoReady = (wmoCount >= 200);

  float ws_send = wmoReady ? wind_speed_avg : windSpeed_ema;
  float gust_send = wmoReady ? wmo_max_gust3 : windgustmph;
  if (gust_send < ws_send) gust_send = ws_send;

  int dir_send = wmoReady ? windDirWMO : (int)roundf(last_dir_measurement);

  float ws_kmh = ws_send * 1.60934f;
  float gust_kmh = gust_send * 1.60934f;

  char data[400];
  snprintf(data, sizeof(data),
           "api_key=%s&field1=%.2f&field2=%.2f&field3=%.2f&field4=%.2f&field5=%.2f&field6=%.2f&field7=%d&field8=%d",
           apiKey, tempc, humidity, pressurehPa, ws_kmh, gust_kmh,
           rain_24h_mm, dir_send, (int)WiFi.RSSI());

  String request = "POST /update HTTP/1.1\r\n";
  request += "Host: api.thingspeak.com\r\n";
  request += "X-THINGSPEAKAPIKEY: " + String(apiKey) + "\r\n";
  request += "Content-Type: application/x-www-form-urlencoded\r\n";
  request += "Content-Length: " + String(strlen(data)) + "\r\n";
  request += "Connection: close\r\n\r\n";
  request += String(data);

  bool ok = false;
  for (int attempt = 1; attempt <= 3 && !ok; attempt++) {
    ok = sendHttpRequest(tsClient, server3, request);
    if (ok) {
      startTransmissionFlash();
    } else if (attempt < 3) {
      smartDelay(2000UL * (1UL << (attempt - 1)));
    }
  }

  if (ok) tsFailures = 0;
  else tsFailures++;

  isTransmitting = false;
}

// ======================== SETUP ========================
void setup() {
  const char* fp = __FILE__;
  PROG_NAME = strrchr(fp, '/') ? strrchr(fp, '/') + 1 : (strrchr(fp, '\\') ? strrchr(fp, '\\') + 1 : fp);

  Serial.begin(115200);
  Serial.println();
  Serial.println(F("=================================="));
  Serial.print(F("AVVIO: "));
  Serial.println(NOME_STAZIONE);
  Serial.println(F("=================================="));

  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);

  pinMode(OFFLINE_LED_PIN, OUTPUT);
  digitalWrite(OFFLINE_LED_PIN, LOW);

  pinMode(WindSensorPin, INPUT_PULLUP);
  pinMode(RainSensorPin, INPUT_PULLUP);
  pinMode(WindDirPin, INPUT);
  pinMode(batteryPin, INPUT);

  analogReadResolution(12);
  analogSetPinAttenuation(WindDirPin, ADC_11db);
  analogSetPinAttenuation(batteryPin, ADC_11db);

  EEPROM.begin(EEPROM_SIZE);
  EEPROM.get(EEPROM_ADDR, crashCount);
  if (crashCount < 0 || crashCount > 30000) crashCount = 0;

  String rr = getResetReasonString();

  if (rr == "Exception" || rr == "Software reset CPU" || rr == "Power on reset" || rr == "RTCWDT_RTC_RESET") {
    // lasciamo il conteggio com'era concettualmente
  }

  if (!LittleFS.begin(true)) {
    Serial.println(F("LittleFS init fallita"));
  }

  appWatchdogLastKick = millis();
  watchdogTicker.attach_ms(10000, checkAppWatchdog);

  WiFi.mode(WIFI_STA);
  wifiMulti.addAP(ssid1, password_1);
  wifiMulti.addAP(ssid2, password_2);
  wifiMulti.addAP(ssid3, password_3);
  wifiMulti.addAP(ssid4, password_4);

  unsigned long t0 = millis();
  while (wifiMulti.run() != WL_CONNECTED && millis() - t0 < 10000UL) {
    appWatchdogLastKick = millis();
    delay(200);
  }

  wasWifiConnected = (WiFi.status() == WL_CONNECTED);
  if (wasWifiConnected) {
    Serial.println();
    Serial.print(F("Connessione WiFi stabilita! Indirizzo IP: "));
    Serial.println(WiFi.localIP());
    Serial.println();
  } else {
    Serial.println();
    Serial.println(F("ATTENZIONE: Connessione WiFi non completata entro i 10 secondi."));
    Serial.println(F("Il dispositivo riproverà in background durante il loop."));
    Serial.println();
  }

  Serial.println(WiFi.localIP());

  httpServer.on("/", HTTP_GET, []() {
    httpServer.send(200, "text/plain", "Stazione meteo attiva. Usa /status");
  });

  httpServer.on("/logs", HTTP_GET, []() {
    File f = LittleFS.open("/error_log.txt", "r");
    if (!f) {
      httpServer.send(200, "text/plain", "Nessun log.");
      return;
    }
    httpServer.streamFile(f, "text/plain");
    f.close();
  });

  httpServer.on("/clearlogs", HTTP_GET, []() {
    LittleFS.remove("/error_log.txt");
    httpServer.send(200, "text/plain", "Log cancellati.");
  });

  httpServer.on("/resetlog", HTTP_GET, []() {
    File f = LittleFS.open("/reset_log.txt", "r");
    if (!f) {
      httpServer.send(200, "text/plain", "Nessun reset registrato.");
      return;
    }
    httpServer.streamFile(f, "text/plain");
    f.close();
  });

  httpServer.on("/clearresetlog", HTTP_GET, []() {
    LittleFS.remove("/reset_log.txt");
    httpServer.send(200, "text/plain", "Reset log cancellato.");
  });

  httpServer.on("/resetstatus", HTTP_GET, []() {
    consecutiveFailures = 0;
    wcFailures = 0;
    tsFailures = 0;
    maxWuFails = 0;
    wifiDisconnects = 0;
    crashCount = 0;
    anomalyEvents = 0;
    EEPROM.put(EEPROM_ADDR, crashCount);
    EEPROM.commit();
    httpServer.send(200, "text/plain", "Contatori azzerati.");
  });

  httpServer.on("/status", HTTP_GET, []() {
    char sTemp[12], sHum[12], sPress[12], upBuf[32], chunk[600];
    unsigned long upSec = millis() / 1000UL;
    unsigned long upDays = upSec / 86400UL;
    unsigned long upHrs = (upSec % 86400UL) / 3600UL;
    unsigned long upMin = (upSec % 3600UL) / 60UL;

    snprintf(upBuf, sizeof(upBuf), "%lu giorni, %02lu ore e %02lu min", upDays, upHrs, upMin);

    if (isnan(tempc) || tempc <= -999.0f) strcpy(sTemp, "null");
    else snprintf(sTemp, sizeof(sTemp), "%.2f", tempc);

    if (isnan(humidity) || humidity == 0.0f) strcpy(sHum, "null");
    else snprintf(sHum, sizeof(sHum), "%.1f", humidity);

    if (isnan(baromhpa) || baromhpa == 0.0f) strcpy(sPress, "null");
    else snprintf(sPress, sizeof(sPress), "%.1f", baromhpa);

    String escStation = jsonEscape(NOME_STAZIONE);
    String escProg = jsonEscape(PROG_NAME);
    String escStartup = jsonEscape(startupDateTime);
    String escLastCrash = jsonEscape(lastCrashDateTime);
    //String escDirText = jsonEscape(windDirToText(getWindDirectionWMO()));
    String escDirText = jsonEscape(windDirToText(windDirWMO));

    String escDirInstText = jsonEscape(windDirToText((int)roundf(last_dir_measurement)));

    // COPIA ATOMICA DEI VALORI USATI NELLA STATUS PAGE
    noInterrupts();
    float local_windSpeed_ema = windSpeed_ema;
    float local_windSpeed_instant = windSpeed;   // mantiene compatibilità con campo "vento_istantaneo"
    float local_ws_avg = wind_speed_avg;         // media 10 min (WMO scorrevole)
    float local_gust3 = windgustmph;             // media 3s corrente
    float local_gust_max = wmo_max_gust3;        // picco 3s nella finestra 10min
    int local_windDirWMO = windDirWMO;           // direzione media 10min
    float local_gust_dir = wmo_dir_at_max_gust;  // direzione associata al picco
    int local_wmoCount = wmoCount;               // numero campioni nella finestra
    uint32_t local_anomalyEvents = anomalyEvents;
    interrupts();

    // Assicurare coerenza: raffica >= velocità (evita visualizzare istantaneo > raffica)
    if (local_gust_max < local_ws_avg) local_gust_max = local_ws_avg;
    if (local_gust3 < local_windSpeed_instant) local_gust3 = local_windSpeed_instant;

    httpServer.setContentLength(CONTENT_LENGTH_UNKNOWN);
    httpServer.sendHeader("Access-Control-Allow-Origin", "*");
    httpServer.send(200, "application/json", "");

    httpServer.sendContent(F("{\n"));
    httpServer.sendContent(F("  \"sistema\": {\n"));

    httpServer.sendContent(F("    \"nome_stazione\": \""));
    httpServer.sendContent(escStation);
    httpServer.sendContent(F("\",\n"));

    httpServer.sendContent(F("    \"firmware\": \""));
    httpServer.sendContent(escProg);
    httpServer.sendContent(F("\",\n"));

    httpServer.sendContent(F("    \"scheda\": \"ESP32 Dev Module\",\n"));

    httpServer.sendContent(F("    \"avvio\": \""));
    httpServer.sendContent(escStartup);
    httpServer.sendContent(F("\",\n"));

    httpServer.sendContent(F("    \"ultimo_crash\": \""));
    httpServer.sendContent(escLastCrash);
    httpServer.sendContent(F("\",\n"));

    snprintf(chunk, sizeof(chunk),
             "    \"uptime\": \"%s\",\n"
             "    \"wifi_connesso\": %s,\n"
             "    \"internet_raggiungibile\": %s,\n"
             "    \"rssi_dbm\": %d,\n"
             "    \"heap_libero_bytes\": %u,\n"
             "    \"contatore_crash\": %d,\n"
             "    \"anomaly_events\": %lu,\n"
             "    \"wunderground_fallimenti\": %d,\n"
             "    \"weathercloud_fallimenti\": %d,\n"
             "    \"thingspeak_fallimenti\": %d,\n"
             "    \"wifi_disconnects\": %d\n",

             upBuf,
             (WiFi.status() == WL_CONNECTED ? "true" : "false"),
             (internetReachable ? "true" : "false"),
             WiFi.RSSI(),
             ESP.getFreeHeap(),
             crashCount,
             (unsigned long)local_anomalyEvents,
             consecutiveFailures,
             wcFailures,
             tsFailures,
             wifiDisconnects);
    httpServer.sendContent(chunk);
    httpServer.sendContent(F("  },\n"));

    snprintf(chunk, sizeof(chunk),
             "  \"rete\": {\n"
             "    \"last_wifi_drop\": \"%s\",\n"
             "    \"last_wifi_restore\": \"%s\",\n"
             "    \"last_internet_drop\": \"%s\",\n"
             "    \"last_internet_restore\": \"%s\"\n"
             "  },\n",
             lastWifiDropTime,
             lastWifiRestoreTime,
             lastInternetDropTime,
             lastInternetRestoreTime);
    httpServer.sendContent(chunk);

    // SENSORS / WIND: usare i valori locali coerenti
    snprintf(chunk, sizeof(chunk),
             "  \"sensori\": {\n"
             "    \"temperatura_C\": %s,\n"
             "    \"umidita_pct\": %s,\n"
             "    \"pressione_hPa\": %s,\n"
             "    \"batteria_V\": %.2f,\n"
             "    \"pioggia_1h_mm\": %.2f,\n"
             "    \"pioggia_24h_mm\": %.2f,\n"
             "    \"vento_istantaneo_mph\": %.2f,\n"
             "    \"vento_istantaneo_kmh\": %.2f,\n"
             "    \"vento_medio_10m_mph\": %.2f,\n"
             "    \"vento_medio_10m_kmh\": %.2f,\n"
             "    \"raffica_3s_mph\": %.2f,\n"
             "    \"raffica_3s_kmh\": %.2f,\n"
             "    \"raffica_max_10m_mph\": %.2f,\n"
             "    \"raffica_max_10m_kmh\": %.2f,\n"
             "    \"direzione_media_gradi\": %d,\n"
             "    \"direzione_istantanea_gradi\": %d,\n",
             sTemp, sHum, sPress,
             batteryVoltage,
             rain_1h_mm, rain_24h_mm,
             local_windSpeed_instant, local_windSpeed_instant * 1.60934f,
             local_ws_avg, local_ws_avg * 1.60934f,
             local_gust3, local_gust3 * 1.60934f,
             local_gust_max, local_gust_max * 1.60934f,
             local_windDirWMO,
             (int)roundf(last_dir_measurement));
    httpServer.sendContent(chunk);

    // direzioni testuali e campioni
    httpServer.sendContent(F("    \"direzione_media_testo\": \""));
    httpServer.sendContent(escDirText);
    httpServer.sendContent(F("\",\n"));

    httpServer.sendContent(F("    \"direzione_istantanea_testo\": \""));
    httpServer.sendContent(escDirInstText);
    httpServer.sendContent(F("\",\n"));

    // aggiungo gust_dir e numero campioni WMO
    snprintf(chunk, sizeof(chunk),
             "    \"gust_dir_degrees\": %.1f,\n"
             "    \"campioni_wmo\": %d\n"
             "  }\n"
             "}\n",
             local_gust_dir,
             local_wmoCount);
    httpServer.sendContent(chunk);
  });

  ElegantOTA.begin(&httpServer);
  httpServer.begin();

  Wire.begin(I2C_SDA, I2C_SCL);
  DS18B20.begin();
  sht31.begin(0x44);
  if (!bmp.begin(0x76)) bmp.begin(0x77);

  Udp.begin(localPort);
  setSyncProvider(getNtpTimeDynamic);
  setSyncInterval(300);

  unsigned long ntpT = millis();
  while (timeStatus() == timeNotSet && millis() - ntpT < 20000UL) {
    appWatchdogLastKick = millis();
    delay(300);
  }

  //updateTimezone();
  loadRainData();
  readBatteryVoltage();

  formatCurrentDateTime(startupDateTime, sizeof(startupDateTime));
  saveResetEvent();

  {
    File cf = LittleFS.open("/last_crash.txt", "r");
    if (cf) {
      String line = cf.readStringUntil('\n');
      line.trim();
      strlcpy(lastCrashDateTime, line.c_str(), sizeof(lastCrashDateTime));
      cf.close();
    }
  }

  //pinMode(RainSensorPin, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(RainSensorPin), isr_rg, FALLING);
  attachInterrupt(digitalPinToInterrupt(WindSensorPin), isr_rotation, FALLING);

  last_speed_sample = millis();
  last_dir_sample = millis();
  last_wmo_update = millis();

  char msgAvvio[320];
  snprintf(msgAvvio, sizeof(msgAvvio),
           "STAZIONE AVVIATA\n"
           "Stazione: %s\n"
           "File: %s\n"
           "Ora avvio: %s\n"
           "Motivo Reset: %s\n"
           "Crash Totali: %d",
           NOME_STAZIONE, PROG_NAME, startupDateTime, getResetReasonString().c_str(), crashCount);
  sendTelegramMessage(msgAvvio);
}

// ======================== LOOP ========================
void loop() {
  unsigned long now = millis();

  if (wdtRestartTriggered) {
    logError("WDT app: riavvio forzato");
    delay(100);
    ESP.restart();
  }

  appWatchdogLastKick = now;

  httpServer.handleClient();
  ElegantOTA.loop();
  delay(1);

  bool wifiOk = (wifiMulti.run() == WL_CONNECTED);
  if (wifiOk && !wasWifiConnected) {
    wasWifiConnected = true;
    formatCurrentDateTime(lastWifiRestoreTime, sizeof(lastWifiRestoreTime));
    char msg[192];
    snprintf(msg, sizeof(msg), "Wi-Fi ripristinato alle %s\nEra caduto alle: %s",
             lastWifiRestoreTime, lastWifiDropTime);
    sendTelegramMessage(msg);
  } else if (!wifiOk && wasWifiConnected) {
    wifiDisconnects++;
    wasWifiConnected = false;
    formatCurrentDateTime(lastWifiDropTime, sizeof(lastWifiDropTime));
    logError("Disconnessione Wi-Fi");
  }

  if (now - lastInternetCheck >= INTERNET_CHECK_MS) {
    lastInternetCheck = now;
    bool currentInternet = wifiOk ? checkInternet() : false;

    if (currentInternet && !internetReachable) {
      if (strcmp(startupDateTime, "Non disponibile") != 0 && strcmp(startupDateTime, "Ora non sincronizzata") != 0) {
        formatCurrentDateTime(lastInternetRestoreTime, sizeof(lastInternetRestoreTime));
        if (errNotified_Internet) {
          char msg[224];
          snprintf(msg, sizeof(msg), "Internet ripristinato alle %s\nEra caduto alle: %s",
                   lastInternetRestoreTime, lastInternetDropTime);
          sendTelegramMessage(msg);
          errNotified_Internet = false;
        }
      }
    } else if (!currentInternet && internetReachable) {
      formatCurrentDateTime(lastInternetDropTime, sizeof(lastInternetDropTime));
    }

    internetReachable = currentInternet;
    // --- NUOVO PARACADUTE NTP ---
    // Se internet c'è, ma l'ora non è ancora stata impostata, forza la sincronizzazione
    if (internetReachable && timeStatus() == timeNotSet) {
      setSyncProvider(getNtpTimeDynamic);
    }
  }

  static unsigned long lastSensor = 0;
  if (now - lastSensor >= 5000UL) {
    lastSensor = now;
    read_data();
    checkHumidityStability();
    recoverSensorsIfNeeded();
  }

  static unsigned long lastBattRead = 0;
  if (now - lastBattRead >= 10000UL) {
    lastBattRead = now;
    readBatteryVoltage();
  }

  getRain();

  if (humidity < 5.0f || humidity > 100.0f) {
    if (!errNotified_SHT31) {
      sendTelegramMessage("ALLARME: SHT31 non risponde");
      errNotified_SHT31 = true;
    }
  } else if (errNotified_SHT31) {
    sendTelegramMessage("RISOLTO: SHT31 funziona");
    errNotified_SHT31 = false;
  }

  if (tempc <= -999.0f) {
    if (!errNotified_DS18B20) {
      sendTelegramMessage("ALLARME: DS18B20 non risponde");
      errNotified_DS18B20 = true;
    }
  } else if (errNotified_DS18B20) {
    sendTelegramMessage("RISOLTO: DS18B20 funziona");
    errNotified_DS18B20 = false;
  }

  if (isnan(baromhpa) || baromhpa == 0.0f || baromhpa < 940.0f || baromhpa > 1060.0f) {
    if (!errNotified_BMP280) {
      sendTelegramMessage("ALLARME: BMP280 non risponde");
      errNotified_BMP280 = true;
    }
  } else if (errNotified_BMP280) {
    sendTelegramMessage("RISOLTO: BMP280 funziona");
    errNotified_BMP280 = false;
  }

  processWindData();

  // --- INIZIO BLOCCO TRASMISSIONE ---
  bool hasTransmitted = false;  // Flag per capire se abbiamo inviato dati in questo giro

  if (wifiOk && internetReachable && now - lastWU >= WU_INTERVAL) {
    lastWU = now;
    wunderground();
    hasTransmitted = true;
  }
  if (wifiOk && internetReachable && now - lastWC >= WC_INTERVAL) {
    lastWC = now;
    weathercloud();
    hasTransmitted = true;
  }
  if (wifiOk && internetReachable && now - lastTS >= TS_INTERVAL) {
    lastTS = now;
    thingspeak();
    hasTransmitted = true;
  }

  // --- FINE BLOCCO TRASMISSIONE ---

  if (rainDataToSave && (now - lastEEPROMSave >= EEPROM_MIN_WRITE_GAP)) {
    saveRainData();
    rainDataToSave = false;
    lastEEPROMSave = now;
  }

  if (isFlashing) {
    unsigned long lm = millis();
    if (lm - flashStartTime <= FLASH_DURATION) {
      if (lm - lastLedToggle >= FLASH_SPEED) {
        lastLedToggle = lm;
        static bool ls = false;
        ls = !ls;
        digitalWrite(LED_PIN, ls ? HIGH : LOW);
      }
    } else {
      isFlashing = false;
      digitalWrite(LED_PIN, LOW);
    }
  }

  bool offline = (!wifiOk) || (!internetReachable);
  if (offline) {
    if (!errNotified_Internet) errNotified_Internet = true;
    digitalWrite(OFFLINE_LED_PIN, (millis() % 1000UL) < 500UL ? HIGH : LOW);
  } else {
    digitalWrite(OFFLINE_LED_PIN, LOW);
  }
}
