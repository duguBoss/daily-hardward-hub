// ---------- Sliding window WMO (10 min) with gust direction ----------
#define WMO_WINDOW_SEC 600   // 10 minutes
#define WMO_MAX_SAMPLES 700  // margine (>= WMO_WINDOW_SEC)

struct WindSample {
  uint32_t ts;    // seconds epoch (millis()/1000)
  float speed;    // mph (instantaneous speed_raw)
  float dir_deg;  // direction in degrees associated to this sample
  float dir_sin;  // sin(dir) * speed
  float dir_cos;  // cos(dir) * speed
  float gust3;    // 3s average at that second (mph)
};

